            "indexes": [
                {
                    "key": "content-hash-unique",
                    "type": "unique",
                    "status": "available",
                    "columns": [
                        "contentHash"
                    ],
                    "orders": []
                },
                {
                    "key": "status-index",
                    "type": "key",
                    "status": "available",
                    "columns": [
                        "status"
                    ],
                    "orders": []
                }
            ]
        },
        {
            "$id": "device-pairs",
            "$permissions": [],
            "databaseId": "lhic-shared-registry",
            "name": "Magic URL Device Pairs",
            "enabled": true,
            "rowSecurity": true,
            "columns": [
                {
                    "key": "codeHash",
                    "type": "varchar",
