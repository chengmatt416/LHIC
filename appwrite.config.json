                    "required": true,
                    "array": false,
                    "size": 128,
                    "default": null,
                    "encrypt": false
                },
                {
                    "key": "payload",
                    "type": "text",
                    "required": true,
                    "array": false,
                    "default": null,
                    "encrypt": false
                },
                {
                    "key": "fastPathEligible",
