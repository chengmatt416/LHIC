{
    "organizationId": "6a1787e5cfdd39755fd3",
    "projectId": "lhic-shared-skills",
    "projectName": "LHIC Shared Skills",
    "functions": [
        {
            "$id": "lhic-shared-registry",
            "name": "LHIC Shared Skill Registry",
            "runtime": "node-22",
            "path": "services/appwrite-shared-skills",
            "entrypoint": "src/main.js",
            "execute": [
                "any"
            ],
            "enabled": true,
            "logging": false,
            "events": [],
            "schedule": "",
            "timeout": 30,
            "commands": "npm ci --omit=dev",
            "scopes": [
                "rows.read",
                "rows.write"
            ],
            "buildSpecification": "s-2vcpu-2gb",
            "runtimeSpecification": "s-0.5vcpu-512mb",
