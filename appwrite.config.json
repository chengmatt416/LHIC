            "$id": "lhic-shared-registry",
            "name": "LHIC Shared Skill Registry",
            "enabled": true
        }
    ],
    "tables": [
        {
            "$id": "shared-skills",
            "$permissions": [],
            "databaseId": "lhic-shared-registry",
            "name": "Shared Skills",
            "enabled": true,
            "rowSecurity": true,
            "columns": [
                {
                    "key": "name",
                    "type": "varchar",
                    "required": true,
                    "array": false,
                    "size": 128,
                    "default": null,
                    "encrypt": false
                },
                {
                    "key": "contentHash",
                    "type": "varchar",
                    "required": true,
                    "array": false,
                    "size": 128,
                    "default": null,
                    "encrypt": false
                },
                {
                    "key": "operationKey",
                    "type": "varchar",
                    "required": true,
                    "array": false,
                    "size": 256,
                    "default": null,
                    "encrypt": false
                },
                {
                    "key": "fingerprint",
