{
  "name": "local-human-intent-controller",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0 <25",
    "npm": ">=11.0.0"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "build": "tsc -b --pretty false && node apps/cli/scripts/prepare-package.mjs",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "npm run build && node apps/cli/dist/main.js start",
    "desktop:build": "npm run build --workspace @lhic/desktop",
    "desktop:start": "npm run desktop:build && npm run start --workspace @lhic/desktop",
    "desktop:package": "npm run package --workspace @lhic/desktop",
    "demo": "tsx apps/cli/src/main.ts demo",
    "mcp:config": "npm run build && node apps/cli/dist/main.js mcp config codex .",
    "demo:render": "tsx demos/render-demo.ts",
    "demo:render:build-week": "tsx demos/render-demo.ts --build-week",
    "demo:render:build-week:vendor": "tsx demos/render-demo.ts --build-week --vendor-live",
    "pw:install": "playwright install chromium",
    "bench:internal": "tsx apps/cli/src/main.ts bench internal",
    "bench:simulate": "tsx apps/cli/src/main.ts bench simulate resilience",
    "trace:inspect": "tsx apps/cli/src/main.ts trace inspect",
    "preflight": "tsx apps/cli/src/main.ts preflight",
    "package:smoke": "node scripts/package-smoke.mjs",
    "package:alias-smoke": "node scripts/alias-package-smoke.mjs",
    "package:published-smoke": "node scripts/published-package-smoke.mjs",
    "package:published-alias-smoke": "node scripts/published-alias-smoke.mjs",
    "check:docs": "node scripts/check-doc-links.mjs",
    "check:cli-release-tag": "node scripts/check-cli-release-tag.mjs",
    "scan:secrets": "node scripts/secret-scan.mjs",
    "release:checksums": "npm run release:checksums --workspace @lhic/desktop",
    "check:release-versions": "node scripts/check-release-versions.mjs",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "ci": "npm run format:check && npm run typecheck && npm test && npm run lint && npm run build && npm run bench:internal && npm run preflight && npm run audit:prod && npm run check:docs && npm run check:release-versions && npm run scan:secrets"
  },
  "dependencies": {
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "prettier": "^3.9.6",
    "tsx": "^4.20.3",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
