{
  "name": "@pinyencheng/lhic",
  "version": "0.1.2",
  "description": "Local-first browser and global desktop intent controller for macOS, Windows, and Linux.",
  "license": "MIT OR Apache-2.0",
  "engines": {
    "node": ">=24.0.0 <25",
    "npm": ">=11.0.0"
  },
  "keywords": [
    "automation",
    "browser",
    "desktop",
    "macos",
    "windows",
    "linux"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chengmatt416/LHIC.git"
  },
  "type": "module",
  "exports": {
    ".": "./dist/main.js",
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "bin": {
    "lhic": "dist/main.js"
  },
  "scripts": {
    "build": "tsc -b",
    "prepack": "node ./scripts/clean-dist.mjs && npm run build && node ./scripts/prepare-package.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "bundleDependencies": [
    "@lhic/browser",
    "@lhic/controller",
    "@lhic/game-training",
    "@lhic/game-training-2d",
    "@lhic/game-training-3d",
    "@lhic/memory",
    "@lhic/schema",
    "@lhic/security",
    "@lhic/shared-skills",
    "@lhic/skills",
    "@lhic/trace",
    "@lhic/verifier"
  ],
  "dependencies": {
    "@napi-rs/keyring": "^1.3.0",
    "@lhic/browser": "^0.1.0",
    "@lhic/controller": "^0.1.0",
    "@lhic/game-training": "^0.1.0",
    "@lhic/game-training-2d": "^0.1.0",
    "@lhic/game-training-3d": "^0.1.0",
    "@lhic/memory": "^0.1.0",
    "@lhic/schema": "^0.1.0",
    "@lhic/security": "^0.1.0",
    "@lhic/shared-skills": "^0.1.0",
    "@lhic/skills": "^0.1.0",
    "@lhic/trace": "^0.1.0",
    "@lhic/verifier": "^0.1.0",
    "playwright": "^1.61.1"
  }
}
