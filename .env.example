# Use production only with an explicit HTTPS allowlist.
LHIC_ENV=development
# LHIC_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
LHIC_ALLOW_PRIVATE_NETWORK=false
LHIC_ACTION_TIMEOUT_MS=10000
LHIC_MAX_WAIT_MS=30000
LHIC_TRACE_DIRECTORY=traces
# The MCP browser is visible by default. Set true only for unattended harnesses.
# LHIC_MCP_HEADLESS=true

# Fast Path requires no model environment variables.
# Optional Slow Path only; disabled unless explicitly set to true.
# Multi-path routing remains on the legacy facade until shadow traces are reviewed.
LHIC_PATH_ROUTING_MODE=legacy
LHIC_EXECUTION_PROFILE=fast_only
CLAUDE_SLOW_PATH_ENABLED=false
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=

# Optional GPT-5.6 Slow Path only; Fast Path never uses these values.
OPENAI_SLOW_PATH_ENABLED=false
# OPENAI_API_KEY=
# LHIC_OPENAI_MODEL=gpt-5.6

# Desktop Control Center / Appwrite control-plane deployment only.
# Keep all actual values in Appwrite Function secrets or the OS keychain.
# LHIC_BOOTSTRAP_ADMIN_ACCOUNT_ID=<existing-appwrite-account-id>
# LHIC_CONTROL_ROLES_TABLE_ID=control-roles
# LHIC_CONTROL_JUDGES_TABLE_ID=judge-grants
# LHIC_CONTROL_JUDGE_EMAILS_TABLE_ID=judge-email-grants
# LHIC_CONTROL_JUDGE_TOKENS_TABLE_ID=judge-auth-tokens
# LHIC_CONTROL_DEMO_KEYS_TABLE_ID=demo-api-keys
# LHIC_CONTROL_SECRETS_TABLE_ID=control-secrets
# LHIC_CONTROL_AUDIT_TABLE_ID=control-audit-events
# LHIC_CONTROL_DEMO_ASSETS_TABLE_ID=demo-assets
# LHIC_SECRET_ENCRYPTION_KEY=<base64-encoded-32-byte-key>
